<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DeepSeek · 智能体工作室</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #f7f9fc; --surface: #ffffff; --border: #e2e8f0;
      --text: #0b1a33; --text-secondary: #4a5a72;
      --primary: #1a5cff; --primary-hover: #0d47cc;
      --primary-light: #e6edfe; --code-bg: #f1f4f9;
      --shadow: 0 4px 16px rgba(0,20,60,0.06);
      --radius: 12px; --transition: 0.25s ease;
      --blur-bg: rgba(0,0,0,0.5); --sidebar-width: 300px;
    }
    body.dark {
      --bg: #0d1117; --surface: #161b22; --border: #30363d;
      --text: #f0f6fc; --text-secondary: #8b949e;
      --primary: #3b82f6; --primary-hover: #5690f0;
      --primary-light: #1c2a3f; --code-bg: #1c2128;
      --shadow: 0 4px 16px rgba(0,0,0,0.5);
      --blur-bg: rgba(0,0,0,0.7);
    }
    body {
      background: var(--bg); color: var(--text);
      font-family: -apple-system, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
      transition: background var(--transition), color var(--transition);
      min-height: 100vh; display: flex;
    }
    .sidebar {
      position: fixed; top: 0; left: -320px;
      width: var(--sidebar-width); height: 100%;
      background: var(--surface); border-right: 1px solid var(--border);
      padding: 20px 16px; overflow-y: auto;
      transition: left 0.3s ease; z-index: 2000;
      box-shadow: 2px 0 20px rgba(0,0,0,0.08);
    }
    .sidebar.open { left: 0; }
    .sidebar-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 20px; padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }
    .sidebar-header h3 { font-size: 16px; font-weight: 600; }
    .sidebar-close {
      background: none; border: none; font-size: 24px;
      cursor: pointer; color: var(--text-secondary);
    }
    .chat-list {
      list-style: none; display: flex; flex-direction: column;
    }
    .chat-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 10px 12px; border-radius: 8px; cursor: pointer;
      transition: background var(--transition); margin-bottom: 4px;
      position: relative; flex-wrap: wrap;
    }
    .chat-item:hover { background: var(--primary-light); }
    .chat-item.active {
      background: var(--primary-light); border-left: 3px solid var(--primary);
    }
    .chat-item .chat-info { flex: 1; min-width: 0; margin-right: 8px; }
    .chat-item .chat-name {
      font-size: 14px; font-weight: 500;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .chat-item .chat-agent-label {
      font-size: 11px; color: var(--text-secondary); opacity: 0.7;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .chat-item .chat-actions { position: relative; flex-shrink: 0; }
    .chat-item .dot-menu {
      background: none; border: none; font-size: 18px;
      cursor: pointer; color: var(--text-secondary); padding: 0 4px;
    }
    .chat-item .dot-menu:hover { color: var(--text); }
    .delete-popup {
      display: none; position: absolute; right: 0; top: 28px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 8px; padding: 6px 14px; box-shadow: var(--shadow);
      z-index: 10; font-size: 13px; color: #e74c3c; cursor: pointer;
    }
    .delete-popup:hover { background: #fee; }
    .delete-popup.open { display: block; }
    .main-content {
      flex: 1; padding: 20px 24px; max-width: 1100px;
      margin: 0 auto; width: 100%;
    }
    .header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 0 24px; border-bottom: 1px solid var(--border);
      flex-wrap: wrap; gap: 12px;
    }
    .header-left { display: flex; align-items: center; gap: 14px; }
    .menu-btn {
      background: none; border: none; font-size: 26px;
      cursor: pointer; color: var(--text); padding: 0 4px;
    }
    .logo { font-size: 22px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
    .logo span { color: var(--primary); }
    .header-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .btn {
      background: var(--surface); border: 1px solid var(--border);
      color: var(--text); padding: 8px 18px; border-radius: 30px;
      font-size: 14px; font-weight: 450; cursor: pointer;
      transition: all var(--transition); display: inline-flex;
      align-items: center; gap: 6px;
    }
    .btn:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
    .btn-primary { background: var(--primary); border-color: var(--primary); color: #fff; }
    .btn-primary:hover { background: var(--primary-hover); border-color: var(--primary-hover); color: #fff; }
    .agent-bar {
      display: flex; flex-wrap: wrap; gap: 8px;
      margin: 20px 0 24px; align-items: center;
    }
    .agent-pill {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 40px; padding: 8px 20px; font-size: 14px;
      cursor: pointer; transition: all var(--transition);
      color: var(--text-secondary); display: inline-flex;
      align-items: center; gap: 6px;
    }
    .agent-pill.active {
      border-color: var(--primary); background: var(--primary-light);
      color: var(--primary); font-weight: 500;
    }
    .agent-pill:hover { border-color: var(--primary); }
    .agent-pill .agent-delete-btn {
      background: none; border: none; color: var(--text-secondary);
      cursor: pointer; font-size: 16px; padding: 0 2px;
      opacity: 0.4; transition: opacity 0.2s;
    }
    .agent-pill .agent-delete-btn:hover { opacity: 1; color: #e74c3c; }
    .chat-window {
      background: var(--surface); border-radius: var(--radius);
      border: 1px solid var(--border); box-shadow: var(--shadow);
      padding: 20px 20px 12px; margin-bottom: 16px;
      min-height: 380px; max-height: 520px; overflow-y: auto;
      will-change: transform;
    }
    .message {
      margin-bottom: 18px;
      animation: fadeIn 0.15s ease;
      opacity: 1;
      transition: opacity 0.1s;
    }
    .message .role {
      font-size: 13px; font-weight: 500; color: var(--text-secondary);
      margin-bottom: 4px;
    }
    .message .content {
      font-size: 15px; line-height: 1.6; white-space: pre-wrap; word-break: break-word;
    }
    .message .content code {
      display: block; background: var(--code-bg); padding: 14px 16px;
      border-radius: 8px; font-size: 14px; overflow-x: auto;
      margin: 10px 0 6px; border-left: 3px solid var(--primary);
      font-family: "JetBrains Mono", monospace;
    }
    .copy-btn {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 20px; padding: 4px 14px; font-size: 12px;
      color: var(--text-secondary); cursor: pointer;
      transition: all var(--transition); margin-top: 4px;
    }
    .copy-btn:hover { border-color: var(--primary); color: var(--primary); }
    @keyframes fadeIn {
      from { opacity: 0.4; transform: translateY(2px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .input-area {
      display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap;
    }
    .input-area textarea {
      flex: 1; background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 12px 16px; font-size: 15px;
      font-family: inherit; color: var(--text); resize: vertical;
      min-height: 48px; transition: border var(--transition);
    }
    .input-area textarea:focus { outline: none; border-color: var(--primary); }
    .input-area .btn {
      padding: 10px 28px; background: var(--primary);
      border-color: var(--primary); color: #fff; font-weight: 500; height: 48px;
    }
    .input-area .btn:hover { background: var(--primary-hover); border-color: var(--primary-hover); }
    .modal-overlay {
      display: none; position: fixed; top: 0; left: 0;
      width: 100%; height: 100%; background: var(--blur-bg);
      backdrop-filter: blur(8px); z-index: 3000;
      justify-content: center; align-items: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: var(--surface); border-radius: var(--radius);
      padding: 32px 36px; max-width: 520px; width: 90%;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      border: 1px solid var(--border); animation: slideUp 0.3s ease;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px) scale(0.96); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .modal-box h2 { font-size: 20px; font-weight: 600; margin-bottom: 20px; color: var(--text); }
    .modal-row { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
    .modal-row label { font-size: 14px; font-weight: 450; color: var(--text-secondary); }
    .modal-row select, .modal-row input, .modal-row textarea {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 14px; font-size: 14px;
      color: var(--text); font-family: inherit;
    }
    .modal-row select:focus, .modal-row input:focus, .modal-row textarea:focus {
      outline: none; border-color: var(--primary);
    }
    .modal-row textarea { min-height: 70px; resize: vertical; }
    .modal-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px; }
    .modal-actions .btn { padding: 8px 28px; }
    .footer {
      margin-top: 24px; font-size: 13px; color: var(--text-secondary);
      text-align: center; border-top: 1px solid var(--border); padding-top: 18px;
    }
    @media (max-width: 640px) {
      .header { flex-direction: row; flex-wrap: wrap; }
      .sidebar { width: 260px; left: -280px; }
      .agent-bar { gap: 6px; }
      .agent-pill { font-size: 13px; padding: 6px 14px; }
      .input-area { flex-direction: column; }
      .input-area .btn { width: 100%; justify-content: center; }
      .modal-box { padding: 24px 20px; }
    }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  </style>
</head>
<body>

<div class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <h3 id="sidebarTitle">≡ 聊天记录</h3>
    <button class="sidebar-close" id="sidebarClose">✕</button>
  </div>
  <ul class="chat-list" id="chatList"></ul>
</div>

<div class="main-content">
  <div class="header">
    <div class="header-left">
      <button class="menu-btn" id="menuBtn">≡</button>
      <div class="logo" id="logo">◈ <span>Deep</span>Seek · 智能体</div>
    </div>
    <div class="header-actions">
      <button class="btn" id="newChatBtn">＋ 新聊天</button>
      <button class="btn" id="toggleSettingsBtn">⚙ 设置</button>
      <button class="btn" id="toggleCreateBtn">＋ 创建智能体</button>
    </div>
  </div>

  <div class="agent-bar" id="agentBar"></div>
  <div class="chat-window" id="chatWindow"></div>

  <div class="input-area">
    <textarea id="userInput" rows="1" placeholder=""></textarea>
    <button class="btn" id="sendBtn">发送</button>
  </div>

  <div class="footer" id="footerText">DeepSeek · 开放智能体 · 本地存储</div>
</div>

<div class="modal-overlay" id="settingsModal">
  <div class="modal-box">
    <h2 id="settingsTitle">⚙ 设置</h2>
    <div class="modal-row"><label id="langLabel">界面语言</label><select id="langSelect"><option value="zh">中文</option><option value="ru">Русский</option><option value="en">English</option></select></div>
    <div class="modal-row"><label id="themeLabel">主题</label><select id="themeSelect"><option value="light">浅色</option><option value="dark">深色</option></select></div>
    <div class="modal-row"><label id="speedLabel">生成速度</label><select id="speedSelect"><option value="10">快速</option><option value="30">标准</option><option value="60">慢速</option></select></div>
    <div class="modal-actions">
      <button class="btn" id="closeSettingsBtn" style="background:var(--bg);">关闭</button>
      <button class="btn btn-primary" id="saveSettingsBtn">保存</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="createModal">
  <div class="modal-box">
    <h2 id="createTitle">＋ 创建智能体</h2>
    <div class="modal-row"><label id="nameLabel">名称</label><input type="text" id="newAgentName" placeholder="例如: 诗人" /></div>
    <div class="modal-row"><label id="promptLabel">系统提示词</label><textarea id="newAgentPrompt" placeholder="你是一位诗人，用中文写诗…"></textarea></div>
    <div class="modal-actions">
      <button class="btn" id="closeCreateBtn" style="background:var(--bg);">取消</button>
      <button class="btn btn-primary" id="createAgentBtn">创建</button>
    </div>
  </div>
</div>

