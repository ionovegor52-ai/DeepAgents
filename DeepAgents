  const newChatBtn = document.getElementById('newChatBtn');
  const toggleSettingsBtn = document.getElementById('toggleSettingsBtn');
  const toggleCreateBtn = document.getElementById('toggleCreateBtn');
  const settingsModal = document.getElementById('settingsModal');
  const createModal = document.getElementById('createModal');
  const closeSettingsBtn = document.getElementById('closeSettingsBtn');
  const closeCreateBtn = document.getElementById('closeCreateBtn');
  const saveSettingsBtn = document.getElementById('saveSettingsBtn');
  const langSelect = document.getElementById('langSelect');
  const themeSelect = document.getElementById('themeSelect');
  const speedSelect = document.getElementById('speedSelect');
  const newAgentName = document.getElementById('newAgentName');
  const newAgentPrompt = document.getElementById('newAgentPrompt');
  const createAgentBtn = document.getElementById('createAgentBtn');
  const settingsTitle = document.getElementById('settingsTitle');
  const createTitle = document.getElementById('createTitle');
  const langLabel = document.getElementById('langLabel');
  const themeLabel = document.getElementById('themeLabel');
  const speedLabel = document.getElementById('speedLabel');
  const nameLabel = document.getElementById('nameLabel');
  const promptLabel = document.getElementById('promptLabel');

  // ================================================================
  //  ЯДРО
  // ================================================================

  function getAgentName(agentId) {
    if (BUILTIN_AGENTS[agentId]) {
      return BUILTIN_AGENTS[agentId].name[state.lang] || BUILTIN_AGENTS[agentId].name.zh;
    }
    const custom = state.customAgents.find(a => a.id === agentId);
    return custom ? custom.name : 'AI';
  }

  function getAgentWelcome(agentId) {
    if (BUILTIN_AGENTS[agentId]) {
      return BUILTIN_AGENTS[agentId].welcome[state.lang] || BUILTIN_AGENTS[agentId].welcome.zh;
    }
    const custom = state.customAgents.find(a => a.id === agentId);
    return custom ? `Здравствуйте! Я ${custom.name}.` : 'Здравствуйте! Я AI.';
  }

  function getSystemPrompt(agentId, lastMessages = []) {
    let prompt = '';
    const agentName = getAgentName(agentId);
    
    if (BUILTIN_AGENTS[agentId]) {
      prompt = BUILTIN_AGENTS[agentId].prompt[state.lang] || BUILTIN_AGENTS[agentId].prompt.zh;
    } else {
      const custom = state.customAgents.find(a => a.id === agentId);
      prompt = custom ? custom.prompt : 'You are a helpful assistant.';
    }

    let fullPrompt = `Ты — "${agentName}". Ты ОБЯЗАН следовать этому промпту: ${prompt}. Ты НЕ должен говорить, что ты ChatGPT, OpenAI, или любая другая модель. Ты — ${agentName}. Отвечай на языке пользователя.`;

    if (lastMessages.length > 0) {
      const history = lastMessages.slice(-10).map(msg => {
        const role = msg.role === 'user' ? t('userRole') : agentName;
        return `${role}: ${msg.content}`;
      }).join('\n');
      fullPrompt += `\n\nВот история последнего диалога (используй её для контекста):\n${history}`;
    }

    return fullPrompt;
  }

  function getCurrentChat() {
    if (!state.currentChatId || !state.chats[state.currentChatId]) {
      const id = String(state.nextChatId++);
      const agentId = 'assistant';
      state.chats[id] = {
        agentId: agentId,
        messages: [{ role: 'assistant', content: getAgentWelcome(agentId) }],
        name: t('newChatDefault'),
        hasUserMessage: false,
      };
      state.currentChatId = id;
    }
    return state.chats[state.currentChatId];
  }

  function getCurrentAgentId() {
    const chat = getCurrentChat();
    return chat.agentId;
  }

  function saveToStorage() {
    const data = {
      chats: state.chats,
      customAgents: state.customAgents,
      nextChatId: state.nextChatId,
      currentChatId: state.currentChatId,
      lang: state.lang,
      theme: state.theme,
      speed: state.speed,
    };
    try {
      localStorage.setItem('deepseek_agent_data', JSON.stringify(data));
    } catch (_) {}
  }

  function loadFromStorage() {
    try {
      const raw = localStorage.getItem('deepseek_agent_data');
      if (!raw) return false;
      const data = JSON.parse(raw);
      state.chats = data.chats || {};
      state.customAgents = data.customAgents || [];
      state.nextChatId = data.nextChatId || 1;
      state.currentChatId = data.currentChatId || null;
      state.lang = data.lang || 'zh';
      state.theme = data.theme || 'light';
      state.speed = data.speed || 30;
      if (state.currentChatId && !state.chats[state.currentChatId]) {
        state.currentChatId = null;
      }
      return true;
    } catch (_) { return false; }
  }

  // ================================================================
  //  ОТРИСОВКА
  // ================================================================

  function renderMessages() {
    const chat = getCurrentChat();
    const scrollPos = chatWindow.scrollTop;
    const isNearBottom = chatWindow.scrollHeight - chatWindow.clientHeight - scrollPos < 50;

    chatWindow.innerHTML = '';
    chat.messages.forEach(msg => {
      const div = document.createElement('div');
      div.className = 'message';
      let roleLabel;
      if (msg.role === 'user') {
        roleLabel = t('userRole');
      } else {
        roleLabel = getAgentName(chat.agentId);
      }
      div.innerHTML = `<div class="role">${roleLabel}</div><div class="content">${formatContent(msg.content)}</div>`;
      chatWindow.appendChild(div);
    });

    if (isNearBottom || chat.messages.length > 0) {
      chatWindow.scrollTop = chatWindow.scrollHeight;
    } else {
      chatWindow.scrollTop = scrollPos;
    }
  }

  function formatContent(text) {
    let html = text;
    const codeRegex = /```(\w*)\n([\s\S]*?)```/g;
    let match;
    const parts = [];
    let lastIdx = 0;
    while ((match = codeRegex.exec(html)) !== null) {
      const code = match[2];
      parts.push(html.slice(lastIdx, match.index));
      const copyText = t('copy');
      parts.push(`<code>${escapeHtml(code)}</code><button class="copy-btn" onclick="copyCode(this)">${copyText}</button>`);
      lastIdx = match.index + match[0].length;
    }
    parts.push(html.slice(lastIdx));
    return parts.join('');
  }

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  window.copyCode = function(btn) {
    const code = btn.previousElementSibling.textContent;
    navigator.clipboard?.writeText(code).then(() => {
      btn.textContent = t('copied');
      setTimeout(() => btn.textContent = t('copy'), 1500);
    });
  };

  function renderAgentPills() {
    agentBar.innerHTML = '';
    const currentAgentId = getCurrentAgentId();

    Object.entries(BUILTIN_AGENTS).forEach(([id, ag]) => {
      const btn = document.createElement('button');
      btn.className = `agent-pill ${currentAgentId === id ? 'active' : ''}`;
      btn.dataset.agent = id;
      btn.textContent = ag.name[state.lang] || ag.name.zh;
      btn.addEventListener('click', () => switchAgent(id));
      agentBar.appendChild(btn);
    });

    state.customAgents.forEach(ag => {
      const btn = document.createElement('button');
      btn.className = `agent-pill custom-agent ${currentAgentId === ag.id ? 'active' : ''}`;
      btn.dataset.agent = ag.id;

      const nameSpan = document.createElement('span');
      nameSpan.textContent = ag.name;
      nameSpan.addEventListener('click', (e) => {
        e.stopPropagation();
        switchAgent(ag.id);
      });

      const deleteBtn = document.createElement('button');
      deleteBtn.className = 'agent-delete-btn';
      deleteBtn.textContent = '×';
      deleteBtn.title = t('delete');
      deleteBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (confirm(t('deleteAgentConfirm').replace('{name}', ag.name))) {
          deleteCustomAgent(ag.id);
        }
      });

      btn.appendChild(nameSpan);
      btn.appendChild(deleteBtn);
      btn.addEventListener('click', (e) => {
        if (e.target === btn) {
          switchAgent(ag.id);
        }
      });
      agentBar.appendChild(btn);
    });
  }

  function deleteCustomAgent(agentId) {
    const agent = state.customAgents.find(a => a.id === agentId);
    if (!agent) return;

    state.customAgents = state.customAgents.filter(a => a.id !== agentId);

    const chatIdsToDelete = [];
    for (const [id, chat] of Object.entries(state.chats)) {
      if (chat.agentId === agentId) {
        chatIdsToDelete.push(id);
      }
    }
    chatIdsToDelete.forEach(id => delete state.chats[id]);

    if (!state.chats[state.currentChatId]) {
      const ids = Object.keys(state.chats);
      if (ids.length > 0) {
        state.currentChatId = ids[0];
      } else {
        const id = String(state.nextChatId++);
        state.chats[id] = {
          agentId: 'assistant',
          messages: [{ role: 'assistant', content: getAgentWelcome('assistant') }],
          name: t('newChatDefault'),
          hasUserMessage: false,
        };
        state.currentChatId = id;
      }
    }

    saveToStorage();
    renderAll();
    alert(t('agentDeleted'));
  }

  function switchAgent(agentId) {
    if (state.isGenerating) return;

    let existingChatId = null;
    for (const [id, chat] of Object.entries(state.chats)) {
      if (chat.agentId === agentId) {
        existingChatId = id;
        break;
      }
    }

    if (existingChatId) {
      state.currentChatId = existingChatId;
    } else {
      const id = String(state.nextChatId++);
      state.chats[id] = {
        agentId: agentId,
        messages: [{ role: 'assistant', content: getAgentWelcome(agentId) }],
        name: t('newChatDefault'),
        hasUserMessage: false,
      };
      state.currentChatId = id;
    }

    renderAll();
    saveToStorage();
  }

  function updatePlaceholder() {
    const chat = getCurrentChat();
    const name = getAgentName(chat.agentId);
    if (userInput.value === '') {
      userInput.placeholder = `${t('placeholder')} (${name})`;
    }
  }

  function renderChatList() {
    chatList.innerHTML = '';
    
    const visibleChats = {};
    for (const [id, chat] of Object.entries(state.chats)) {
      if (chat.hasUserMessage) {
        visibleChats[id] = chat;
      }
    }

    const ids = Object.keys(visibleChats);
    if (ids.length === 0) {
      const li = document.createElement('li');
      li.style.cssText = 'color: var(--text-secondary); font-size: 14px; padding: 12px; text-align: center; list-style: none;';
      li.textContent = t('noChats');
      chatList.appendChild(li);
      return;
    }

    const sortedIds = ids.sort((a, b) => Number(b) - Number(a));

    sortedIds.forEach(id => {
      const chat = visibleChats[id];
      const li = document.createElement('li');
      li.className = `chat-item ${state.currentChatId === id ? 'active' : ''}`;

      const infoDiv = document.createElement('div');
      infoDiv.className = 'chat-info';

      const nameSpan = document.createElement('div');
      nameSpan.className = 'chat-name';
      nameSpan.textContent = chat.name || t('newChatDefault');

      const agentLabel = document.createElement('div');
      agentLabel.className = 'chat-agent-label';
      const agentDisplayName = getAgentName(chat.agentId);
      agentLabel.textContent = t('withAgent').replace('{agent}', agentDisplayName);

      infoDiv.appendChild(nameSpan);
      infoDiv.appendChild(agentLabel);

      infoDiv.addEventListener('click', () => {
        state.currentChatId = id;
        renderAll();
        closeSidebar();
      });

      const actionsDiv = document.createElement('div');
      actionsDiv.className = 'chat-actions';

      const dotBtn = document.createElement('button');
      dotBtn.className = 'dot-menu';
      dotBtn.textContent = '⋮';
      dotBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleDeletePopup(id);
      });

      const deletePopup = document.createElement('div');
      deletePopup.className = `delete-popup ${state.deletePopupOpen === id ? 'open' : ''}`;
      deletePopup.textContent = t('delete');
      deletePopup.addEventListener('click', (e) => {
        e.stopPropagation();
        deleteChat(id);
      });

      actionsDiv.appendChild(dotBtn);
      actionsDiv.appendChild(deletePopup);
      li.appendChild(infoDiv);
      li.appendChild(actionsDiv);
      chatList.appendChild(li);
    });
  }

  function toggleDeletePopup(chatId) {
    if (state.deletePopupOpen === chatId) {
      state.deletePopupOpen = null;
    } else {
      state.deletePopupOpen = chatId;
    }
    renderChatList();
  }

  function deleteChat(chatId) {
    if (state.chats[chatId]) {
      delete state.chats[chatId];
      state.deletePopupOpen = null;
      if (state.currentChatId === chatId) {
        const ids = Object.keys(state.chats);
        if (ids.length > 0) {
          state.currentChatId = ids[0];
        } else {
          state.currentChatId = null;
          getCurrentChat();
        }
      }
      saveToStorage();
      renderAll();
    }
  }

  function createNewChat() {
    if (state.isGenerating) return;
    const currentAgentId = getCurrentAgentId();
    const id = String(state.nextChatId++);
    state.chats[id] = {
      agentId: currentAgentId,
      messages: [{ role: 'assistant', content: getAgentWelcome(currentAgentId) }],
      name: t('newChatDefault'),
      hasUserMessage: false,
    };
    state.currentChatId = id;
    state.deletePopupOpen = null;
    renderAll();
    saveToStorage();
    userInput.value = '';
    userInput.focus();
  }

  // ================================================================
  //  ГЕНЕРАЦИЯ НАЗВАНИЯ
  // ================================================================

  async function generateChatName(chatId, firstUserMessage) {
    if (!firstUserMessage || firstUserMessage.length < 2) return;
    const chat = state.chats[chatId];
    if (!chat) return;

    try {
      const resp = await fetch('https://openrouter.ai/api/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${CONFIG.OPENROUTER_KEY}`,
          'Content-Type': 'application/json',
          'HTTP-Referer': CONFIG.SITE,
        },
        body: JSON.stringify({
          model: CONFIG.MODEL,
          messages: [
            { role: 'system', content: '你是一个命名助手。根据用户的第一条消息，生成一个简短的聊天标题（2-4个词）。只输出标题，不要有其他内容。' },
            { role: 'user', content: firstUserMessage }
          ],
          max_tokens: 20,
          temperature: 0.7,
        }),
      });

      if (resp.ok) {
        const data = await resp.json();
        const name = data.choices?.[0]?.message?.content?.trim();
        if (name && name.length > 0 && name.length < 40) {
          chat.name = name;
          saveToStorage();
          renderChatList();
        }
      }
    } catch (_) {}
  }

  // ================================================================
  //  ОТПРАВКА СООБЩЕНИЙ
  // ================================================================

  async function sendMessage() {
    if (state.isGenerating) return;
    const text = userInput.value.trim();
    if (!text) return;

    const chat = getCurrentChat();
    const isFirstUserMessage = chat.messages.length === 1 && chat.messages[0].role === 'assistant';

    chat.hasUserMessage = true;

    chat.messages.push({ role: 'user', content: text });
    userInput.value = '';
    renderMessages();
    saveToStorage();

    state.isGenerating = true;
    sendBtn.textContent = '…';

    const agentId = chat.agentId;
    const lastMessages = chat.messages.slice(-10);
    const systemPrompt = getSystemPrompt(agentId, lastMessages);

    try {
      const resp = await fetch('https://openrouter.ai/api/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${CONFIG.OPENROUTER_KEY}`,
          'Content-Type': 'application/json',
          'HTTP-Referer': CONFIG.SITE,
        },
        body: JSON.stringify({
          model: CONFIG.MODEL,
          messages: [
            { role: 'system', content: systemPrompt },
            ...chat.messages.map(m => ({ role: m.role, content: m.content }))
          ],
          stream: true,
          temperature: 0.7,
          max_tokens: 2048,
        }),
      });

      if (!resp.ok) {
        const err = await resp.text();
        throw new Error(`API error: ${resp.status} ${err}`);
      }

      const reader = resp.body.getReader();
      const decoder = new TextDecoder();
      let full = '';
      let buffer = '';

      chat.messages.push({ role: 'assistant', content: '' });
      const lastIdx = chat.messages.length - 1;
      
      renderMessages();

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';
        for (const line of lines) {
          if (line.startsWith('data: ')) {
            const data = line.slice(6).trim();
            if (data === '[DONE]') continue;
            try {
              const json = JSON.parse(data);
              const delta = json.choices?.[0]?.delta?.content;
              if (delta) {
                full += delta;
                chat.messages[lastIdx].content = full;
                renderMessages();
                await sleep(state.speed);
              }
            } catch (_) {}
          }
        }
      }
      renderMessages();
      saveToStorage();

      if (isFirstUserMessage) {
        generateChatName(state.currentChatId, text);
      }

    } catch (e) {
      chat.messages.push({ role: 'assistant', content: `Ошибка: ${e.message}` });
      renderMessages();
      saveToStorage();
    }

    state.isGenerating = false;
    sendBtn.textContent = t('send');
  }

  function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

  // ================================================================
  //  НАСТРОЙКИ
  // ================================================================

  function applyTheme(theme) {
    document.body.classList.toggle('dark', theme === 'dark');
    state.theme = theme;
    themeSelect.value = theme;
    saveToStorage();
  }

  function applyLang(lang) {
    state.lang = lang;
    langSelect.value = lang;
    updateUIText();

    for (const [id, chat] of Object.entries(state.chats)) {
      if (chat.messages.length > 0 && chat.messages[0].role === 'assistant') {
        const firstMsg = chat.messages[0].content;
        const isWelcome = firstMsg.includes('你好') || firstMsg.includes('Здравствуйте') || firstMsg.includes('Hello');
        if (isWelcome) {
          chat.messages[0].content = getAgentWelcome(chat.agentId);
        }
      }
      const defaultNames = ['Новый диалог', '新对话', 'New conversation', '新对话', 'New Chat'];
      if (defaultNames.includes(chat.name)) {
        chat.name = t('newChatDefault');
      }
    }

    renderAll();
    saveToStorage();
  }

  function updateUIText() {
    logo.innerHTML = t('logo');
    newChatBtn.textContent = `＋ ${t('newChat')}`;
    toggleSettingsBtn.textContent = `⚙ ${t('settings')}`;
    toggleCreateBtn.textContent = `＋ ${t('create')}`;
    sendBtn.textContent = t('send');
    footerText.textContent = t('footer');
    sidebarTitle.textContent = t('sidebarTitle');

    settingsTitle.textContent = t('settingsTitle');
    createTitle.textContent = `＋ ${t('create')}`;
    langLabel.textContent = t('langLabel');
    themeLabel.textContent = t('themeLabel');
    speedLabel.textContent = t('speedLabel');
    nameLabel.textContent = t('nameLabel');
    promptLabel.textContent = t('promptLabel');

    saveSettingsBtn.textContent = t('save');
    closeSettingsBtn.textContent = t('close');
    closeCreateBtn.textContent = t('cancel');
    createAgentBtn.textContent = t('createBtn');

    const themeOpts = themeSelect.options;
    themeOpts[0].text = t('light');
    themeOpts[1].text = t('dark');

    const speedOpts = speedSelect.options;
    speedOpts[0].text = t('fast');
    speedOpts[1].text = t('standard');
    speedOpts[2].text = t('slow');

    renderAgentPills();
    updatePlaceholder();
    renderChatList();
    renderMessages();
  }

  // ================================================================
  //  СОЗДАНИЕ АГЕНТА
  // ================================================================

  function createCustomAgent() {
    const name = newAgentName.value.trim();
    const prompt = newAgentPrompt.value.trim();
    if (!name || !prompt) {
      alert('请输入名称和提示词');
      return;
    }
    const id = 'custom_' + Date.now();
    state.customAgents.push({ id, name, prompt });

    const chatId = String(state.nextChatId++);
    state.chats[chatId] = {
      agentId: id,
      messages: [{ role: 'assistant', content: getAgentWelcome(id) }],
      name: t('newChatDefault'),
      hasUserMessage: false,
    };
    state.currentChatId = chatId;

    newAgentName.value = '';
    newAgentPrompt.value = '';
    createModal.classList.remove('open');
    renderAll();
    saveToStorage();
    alert(t('agentCreated'));
  }

  // ================================================================
  //  САЙДБАР
  // ================================================================

  function openSidebar() {
    sidebar.classList.add('open');
    state.sidebarOpen = true;
    renderChatList();
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    state.sidebarOpen = false;
    state.deletePopupOpen = null;
  }

  function toggleSidebar() {
    if (state.sidebarOpen) {
      closeSidebar();
    } else {
      openSidebar();
    }
  }

  // ================================================================
  //  МОДАЛКИ
  // ================================================================

  function openModal(modal) { modal.classList.add('open'); }
  function closeModal(modal) { modal.classList.remove('open'); }

  // ================================================================
  //  РЕНДЕР ВСЕГО
  // ================================================================

  function renderAll() {
    renderAgentPills();
    renderMessages();
    updatePlaceholder();
    renderChatList();
    updateUIText();
  }

  // ================================================================
  //  СОБЫТИЯ
  // ================================================================

  menuBtn.addEventListener('click', toggleSidebar);
  sidebarClose.addEventListener('click', closeSidebar);
  document.addEventListener('click', (e) => {
    if (state.sidebarOpen && !sidebar.contains(e.target) && e.target !== menuBtn) {
      closeSidebar();
    }
  });

  newChatBtn.addEventListener('click', createNewChat);

  sendBtn.addEventListener('click', sendMessage);
  userInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  toggleSettingsBtn.addEventListener('click', () => openModal(settingsModal));
  closeSettingsBtn.addEventListener('click', () => closeModal(settingsModal));
  saveSettingsBtn.addEventListener('click', () => {
    applyLang(langSelect.value);
    applyTheme(themeSelect.value);
    state.speed = parseInt(speedSelect.value, 10) || 30;
    closeModal(settingsModal);
  });
  settingsModal.addEventListener('click', (e) => {
    if (e.target === settingsModal) closeModal(settingsModal);
  });

  toggleCreateBtn.addEventListener('click', () => openModal(createModal));
  closeCreateBtn.addEventListener('click', () => closeModal(createModal));
  createAgentBtn.addEventListener('click', createCustomAgent);
  createModal.addEventListener('click', (e) => {
    if (e.target === createModal) closeModal(createModal);
  });

  langSelect.addEventListener('change', (e) => applyLang(e.target.value));
  themeSelect.addEventListener('change', (e) => applyTheme(e.target.value));
  speedSelect.addEventListener('change', (e) => {
    state.speed = parseInt(e.target.value, 10) || 30;
    saveToStorage();
  });

  // ================================================================
  //  ИНИЦИАЛИЗАЦИЯ
  // ================================================================

  function init() {
    const hasStorage = loadFromStorage();

    if (!hasStorage || Object.keys(state.chats).length === 0) {
      const id = String(state.nextChatId++);
      const agentId = 'assistant';
      state.chats[id] = {
        agentId: agentId,
        messages: [{ role: 'assistant', content: getAgentWelcome(agentId) }],
        name: t('newChatDefault'),
        hasUserMessage: false,
      };
      state.currentChatId = id;
    }

    if (!state.currentChatId || !state.chats[state.currentChatId]) {
      const ids = Object.keys(state.chats);
      state.currentChatId = ids.length > 0 ? ids[0] : null;
      if (!state.currentChatId) {
        const id = String(state.nextChatId++);
        const agentId = 'assistant';
        state.chats[id] = {
          agentId: agentId,
          messages: [{ role: 'assistant', content: getAgentWelcome(agentId) }],
          name: t('newChatDefault'),
          hasUserMessage: false,
        };
        state.currentChatId = id;
      }
    }

    applyTheme(state.theme);
    applyLang(state.lang);
    renderAll();
    saveToStorage();

    for (const [id, chat] of Object.entries(state.chats)) {
      if (chat.messages.length > 0 && chat.messages[0].role === 'assistant') {
        const firstMsg = chat.messages[0].content;
        const isWelcome = firstMsg.includes('你好') || firstMsg.includes('Здравствуйте') || firstMsg.includes('Hello');
        if (isWelcome) {
          chat.messages[0].content = getAgentWelcome(chat.agentId);
        }
      }
    }

    userInput.value = '';
    saveToStorage();
    renderAll();
  }

  init();
</script>
</body>
</html>
